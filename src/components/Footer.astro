---
import { loadNav } from '../lib/content-loader';
const { footerLinks } = loadNav();
---

<footer class="border-t border-stl-border mt-16 py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-stl-muted text-sm">
        Built with <span class="text-stl-accent font-mono">[STL]</span> &mdash; This site is AI-native.
        <a href="/.well-known/site.stl" class="text-stl-accent hover:underline ml-1">site.stl</a>
      </div>
      <div class="flex items-center gap-4">
        {footerLinks.map(link => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener"
            class="text-stl-muted hover:text-stl-text transition-colors text-sm"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
    <div class="mt-4 flex flex-col items-center gap-2 text-stl-muted text-xs">
      <div class="flex items-center gap-1">
        <span>Contact:</span>
        <button
          id="copy-email"
          class="text-stl-accent hover:underline cursor-pointer font-mono"
          title="Click to copy"
        >
          contact@stl-lang.org
        </button>
        <span id="copy-feedback" class="text-stl-accent opacity-0 transition-opacity duration-300 ml-1">Copied!</span>
      </div>
      <div>&copy; 2026 scos-lab. Open source under MIT License.</div>
    </div>
  </div>
</footer>

<script>
  document.getElementById('copy-email')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText('contact@stl-lang.org');
    const feedback = document.getElementById('copy-feedback');
    if (feedback) {
      feedback.style.opacity = '1';
      setTimeout(() => { feedback.style.opacity = '0'; }, 2000);
    }
  });
</script>
