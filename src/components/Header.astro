---
import { loadNav } from '../lib/content-loader';
const { mainLinks } = loadNav();

// Separate "Docs" link from others — it becomes a dropdown
const docsLink = mainLinks.find(l => l.href === '/docs');
const otherLinks = mainLinks.filter(l => l.href !== '/docs');

const dropdownItems = [
  { label: 'Documentation', href: '/docs', description: 'Tutorials, guides & API reference' },
  { label: 'Articles', href: '/articles', description: 'Reports, analysis & case studies' },
];
---

<header class="border-b border-stl-border bg-stl-bg/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-stl-accent font-bold text-xl hover:text-stl-accent2 transition-colors">
        <span class="font-mono">[STL]</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6">
        {otherLinks.filter(l => l.order < (docsLink?.order ?? 3)).map(link => (
          <a
            href={link.href}
            class="text-stl-muted hover:text-stl-text transition-colors text-sm font-medium"
          >
            {link.label}
          </a>
        ))}

        {/* Docs Dropdown */}
        <div class="relative" id="docs-dropdown">
          <button
            class="text-stl-muted hover:text-stl-text transition-colors text-sm font-medium flex items-center gap-1"
            id="docs-dropdown-btn"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Docs
            <svg class="w-3.5 h-3.5 transition-transform" id="docs-dropdown-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            class="hidden absolute top-full left-1/2 -translate-x-1/2 pt-2 w-64"
            id="docs-dropdown-menu"
          >
            <div class="bg-stl-bg border border-stl-border rounded-lg shadow-xl py-2">
              {dropdownItems.map(item => (
                <a
                  href={item.href}
                  class="block px-4 py-2.5 hover:bg-stl-surface transition-colors"
                >
                  <span class="block text-sm font-medium text-stl-text">{item.label}</span>
                  <span class="block text-xs text-stl-muted mt-0.5">{item.description}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        {otherLinks.filter(l => l.order > (docsLink?.order ?? 3)).map(link => (
          <a
            href={link.href}
            class="text-stl-muted hover:text-stl-text transition-colors text-sm font-medium"
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://github.com/scos-lab"
          target="_blank"
          rel="noopener"
          class="text-stl-muted hover:text-stl-text transition-colors text-sm"
        >
          GitHub
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" class="md:hidden text-stl-muted hover:text-stl-text p-2" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4">
      {otherLinks.filter(l => l.order < (docsLink?.order ?? 3)).map(link => (
        <a
          href={link.href}
          class="block py-2 text-stl-muted hover:text-stl-text transition-colors text-sm font-medium"
        >
          {link.label}
        </a>
      ))}
      {/* Mobile: show both docs links flat */}
      <div class="py-2">
        <span class="block text-xs font-semibold uppercase tracking-wider text-stl-muted mb-1">Docs</span>
        {dropdownItems.map(item => (
          <a
            href={item.href}
            class="block py-1.5 pl-3 text-stl-muted hover:text-stl-text transition-colors text-sm font-medium"
          >
            {item.label}
          </a>
        ))}
      </div>
      {otherLinks.filter(l => l.order > (docsLink?.order ?? 3)).map(link => (
        <a
          href={link.href}
          class="block py-2 text-stl-muted hover:text-stl-text transition-colors text-sm font-medium"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/scos-lab"
        target="_blank"
        rel="noopener"
        class="block py-2 text-stl-muted hover:text-stl-text transition-colors text-sm"
      >
        GitHub
      </a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Desktop dropdown
  const dropdown = document.getElementById('docs-dropdown');
  const dropdownBtn = document.getElementById('docs-dropdown-btn');
  const dropdownMenu = document.getElementById('docs-dropdown-menu');
  const chevron = document.getElementById('docs-dropdown-chevron');

  let isOpen = false;
  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  function openDropdown() {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    dropdownMenu?.classList.remove('hidden');
    chevron?.classList.add('rotate-180');
    dropdownBtn?.setAttribute('aria-expanded', 'true');
    isOpen = true;
  }

  function closeDropdown() {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    dropdownMenu?.classList.add('hidden');
    chevron?.classList.remove('rotate-180');
    dropdownBtn?.setAttribute('aria-expanded', 'false');
    isOpen = false;
  }

  function closeDropdownDelayed() {
    closeTimer = setTimeout(closeDropdown, 150);
  }

  // Toggle on click
  dropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (isOpen) {
      closeDropdown();
    } else {
      openDropdown();
    }
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (isOpen && !dropdown?.contains(e.target as Node)) {
      closeDropdown();
    }
  });

  // Open on hover, close with delay (desktop)
  dropdown?.addEventListener('mouseenter', openDropdown);
  dropdown?.addEventListener('mouseleave', closeDropdownDelayed);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      closeDropdown();
    }
  });
</script>
